rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidBooking(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && (data.guests is int || data.guests is float) && data.guests >= 1 && data.guests <= 1000
        && data.date is string && data.date.size() <= 64
        && data.time is string && data.time.size() <= 64
        && data.status is string && (data.status == 'Pending' || data.status == 'Confirmed' || data.status == 'Cancelled')
        && (!('specialRequest' in data) || (data.specialRequest is string && data.specialRequest.size() <= 1024))
        && data.createdAt is string && data.createdAt.size() <= 64
        && (!('bookingType' in data) || (data.bookingType is string && (data.bookingType == 'table' || data.bookingType == 'preorder')))
        && (!('preorderDishes' in data) || (data.preorderDishes is string && data.preorderDishes.size() <= 2048));
    }

    // Bookings collection – accessible by anyone to place pre-orders and check in real time.
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidId(bookingId) && isValidBooking(request.resource.data);
      allow update: if isValidId(bookingId) && isValidBooking(request.resource.data);
      allow delete: if isValidId(bookingId);
    }
  }
}
