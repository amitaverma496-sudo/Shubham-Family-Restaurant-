{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Pre-order bookings made by guests.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique booking ID." },
        "name": { "type": "string", "description": "Customer name." },
        "phone": { "type": "string", "description": "Customer phone number." },
        "guests": { "type": "integer", "description": "Number of guests." },
        "date": { "type": "string", "description": "Date of the booking." },
        "time": { "type": "string", "description": "Time of the booking." },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"], "description": "Booking status." },
        "specialRequest": { "type": "string", "description": "Optional special request." },
        "createdAt": { "type": "string", "description": "ISO timestamp for creation." }
      },
      "required": ["id", "name", "phone", "guests", "date", "time", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile with information from Google Sign-In.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Google user ID." },
        "displayName": { "type": "string", "description": "User display name." },
        "email": { "type": "string", "description": "User Gmail/email address." },
        "photoURL": { "type": "string", "description": "User profile photo URL." },
        "lastLogin": { "type": "string", "description": "ISO timestamp for last login." }
      },
      "required": ["uid", "email", "lastLogin"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection storing guest pre-orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection storing registered user profiles from Google Sign-In."
    }
  }
}
